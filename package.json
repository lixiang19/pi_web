{
  "name": "pi-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c cyan,yellow \"npm run dev --workspace @pi/server\" \"npm run dev --workspace @pi/web\"",
    "dev:web": "npm run dev --workspace @pi/web",
    "dev:server": "npm run dev --workspace @pi/server",
    "dev:desktop": "npm run dev --workspace @pi/desktop",
    "build": "npm run build --workspace @pi/server && npm run build --workspace @pi/web",
    "build:web": "npm run build --workspace @pi/web",
    "build:server": "npm run build --workspace @pi/server",
    "build:desktop": "npm run build --workspace @pi/desktop",
    "lint": "eslint . --ext .ts,.vue",
    "lint:fix": "eslint . --ext .ts,.vue --fix",
    "typecheck": "npm run check --workspace @pi/web",
    "check": "npm run lint && npm run typecheck",
    "check:fix": "npm run lint:fix && npm run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "shadcn-vue": "^2.5.3"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
