# Local loopback development may use dev-key.
# Public/production deployments must use a strong non-default secret.
RIDGE_CONVERTER_API_KEYS=dev-key
RIDGE_CONVERTER_PUBLIC_BASE_URL=http://127.0.0.1:8765/v1
RIDGE_CONVERTER_HOST=127.0.0.1
RIDGE_CONVERTER_PORT=8765
RIDGE_CONVERTER_ARTIFACT_DIR=/tmp/ridge-converter
RIDGE_CONVERTER_MAX_FILE_SIZE_BYTES=104857600
RIDGE_CONVERTER_MAX_INLINE_SIZE_BYTES=65536

# Required for default image.ocr and image.description.
# OPENAI_API_KEY is accepted as a compatibility fallback for RIDGE_CONVERTER_VISION_API_KEY.
RIDGE_CONVERTER_VISION_API_KEY=
RIDGE_CONVERTER_VISION_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
RIDGE_CONVERTER_VISION_MODEL=gpt-4.1-mini

# Required for default audio.transcription.
GROQ_API_KEY=
RIDGE_CONVERTER_GROQ_BASE_URL=https://api.groq.com/openai/v1
RIDGE_CONVERTER_GROQ_AUDIO_MODEL=whisper-large-v3-turbo

# Required only when installing ridge-converter[audio].
RIDGE_CONVERTER_WHISPER_MODEL_SIZE=base
