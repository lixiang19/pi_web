{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pi Web",
  "version": "0.1.0",
  "identifier": "com.lixiang19.piweb",
  "build": {
    "beforeDevCommand": "npm --prefix ../../.. run dev",
    "beforeBuildCommand": "npm --prefix ../../.. run build:web",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Pi Web",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}