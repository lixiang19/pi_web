{
  "manifest_version": 3,
  "name": "ridge Reader",
  "description": "Capture actively read pages into ridge fleeting notes.",
  "version": "0.1.0",
  "permissions": ["alarms", "activeTab", "storage", "tabs"],
  "host_permissions": ["http://127.0.0.1:*/*", "http://localhost:*/*", "http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "ridge Reader",
    "default_popup": "popup.html"
  }
}
